  "main": "build/index.js",
  "module": "build/index.es.js",
  "files": [
    "build"
  ],
  "peerDependencies": {
    "@react-spring/web": "^9.4.5",
    "react": "^17.0.1",
    "react-dom": "^17.0.1",
    "react-player": "^2.10.1",
