    "react": "^17.0.1",
    "react-dom": "^17.0.1",
    "react-player": "^2.10.1",
    "swiper": "^8.1.6"
  },
  "scripts": {
    "build": "rollup -c",
    "install-dev": "npm install && rm -rf ./node_modules/react  && rm -rf ./node_modules/react-dom",
    "format": "prettier --write \"**/*.+(ts|tsx)\"",
    "prepublishOnly": "rm -rf /build && npm run build",
    "type-check": "tsc --pretty --noEmit --skipLibCheck",
    "lint": "eslint . --ext ts --ext tsx",
    "prepare": "husky install"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/BlipIQSciences/scene-templates.git"
  },
  "author": "blipiq",
  "license": "",
  "bugs": {
    "url": "https://github.com/BlipIQSciences/scene-templates/issues"
  },
  "homepage": "https://github.com/BlipIQSciences/scene-templates#readme",
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "lint-staged": {
    "*.@(ts|tsx)": [
      "npm run lint",
      "npm run format"
    ]
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^22.0.1",
    "@rollup/plugin-image": "^2.0.6",
    "@rollup/plugin-node-resolve": "^13.3.0",
    "@rollup/plugin-url": "^6.1.0",
    "@typescript-eslint/eslint-plugin": "^5.29.0",
    "@typescript-eslint/parser": "^5.29.0",
    "autoprefixer": "^10.4.7",
    "eslint": "^8.18.0",
    "eslint-config-prettier": "^8.5.0",
    "eslint-plugin-import": "^2.26.0",
    "eslint-plugin-jsx-a11y": "^6.6.0",
    "eslint-plugin-react": "^7.30.1",
    "eslint-plugin-react-hooks": "^4.6.0",
    "husky": "^7.0.4",
    "lint-staged": "^12.5.0",
    "prettier": "^2.7.1",
    "rollup": "^2.75.7",
    "rollup-plugin-import-file": "^1.0.1",
    "rollup-plugin-peer-deps-external": "^2.2.4",
    "rollup-plugin-postcss-modules": "^2.0.2",
    "rollup-plugin-typescript2": "^0.31.2",
